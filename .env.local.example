# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini
GOOGLE_GENERATIVE_AI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# AWS Bedrock
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_REGION=us-east-1

# SQLite DB file path (default: ./data/chat.db)
# DATABASE_PATH=./data/chat.db

# ─── Brave Search MCP Server ───────────────────────────────────────────────────
# APIキーを設定すると Brave Search MCP サーバーが自動的に有効になる
# https://brave.com/search/api/ でAPIキーを取得する
# BRAVE_API_KEY=BSAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── File Output MCP Server ────────────────────────────────────────────────────
# Root directory for session workspaces used by the built-in file output MCP.
# Each chat/task session gets its own subdirectory: {MCP_WORKSPACE_ROOT}/{sessionId}/
# Default (if omitted): ./workspaces
# MCP_WORKSPACE_ROOT=/var/data/chat-workspaces

# ─── Google OAuth 認証（任意）─────────────────────────────────────────────────
# 設定するとログイン画面に「Googleでログイン」ボタンが表示される
# Google Cloud Console で OAuth 2.0 クライアント ID を発行して設定する
# リダイレクト URI: http://localhost:3000/api/auth/callback/google
#
# GOOGLE_CLIENT_ID=xxxxxxxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxx
#
# NextAuth.js セッション署名用シークレット（必須: openssl rand -base64 32 で生成）
# AUTH_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# ドメイン制限（省略可。設定すると指定ドメインのみ許可）
# GOOGLE_ALLOWED_DOMAINS=example.com,sub.example.com
